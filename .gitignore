# Python
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
build/
dist/
*.egg-info/
.eggs/

# Virtual envs
.venv/
venv/
env/

# Testing / coverage
.pytest_cache/
.coverage
.coverage.*
htmlcov/
.mypy_cache/
.ruff_cache/

# Data (generated by ingest.py)
data/
!data/.gitkeep

# Eval reports (generated). The mock-only seed run is checked in so the repo
# shows a representative eval report without needing an Anthropic API key.
evals/reports/*.md
evals/reports/*.json
!evals/reports/.gitkeep
!evals/reports/seed-run.md
!evals/reports/seed-run.json

# Secrets / env
.env
.env.*
!.env.example

# IDE
.vscode/
.idea/
*.swp
.DS_Store

# Terraform
infra/terraform/.terraform/
infra/terraform/*.tfstate
infra/terraform/*.tfstate.backup
infra/terraform/.terraform.lock.hcl
infra/terraform/terraform.tfvars
infra/terraform/*.zip

# Claude cache
.claude/
